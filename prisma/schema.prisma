generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  Developer
  DataAnalyst
  QAEngineer
  ProductManager
  DevOps
  Designer
  HRManager
  ProjectManager
}

enum UserDepartment {
  Engineering
  Analytics
  Product
  Operations
  People
}

enum UserCountry {
  Ukraine
  Poland
  Germany
  Spain
  Netherlands
  Canada
}

enum UserStatus {
  active
  inactive
}

model User {
  id         Int            @id
  name       String
  role       UserRole
  department UserDepartment
  country    UserCountry
  age        Int
  salary     Int
  joinedAt   DateTime
  status     UserStatus

  @@index([role])
  @@index([department])
  @@index([country])
  @@index([status])
  @@index([age])
  @@index([salary])
  @@index([joinedAt])
}